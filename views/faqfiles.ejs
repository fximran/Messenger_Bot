<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FAQ Files - Bot Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <style>
        body { background: #f8f9fa; }
        .card { margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .modal-body pre { background: #1e1e1e; color: #ddd; padding: 15px; border-radius: 5px; }
    </style>
</head>
<body>
<div class="d-flex flex-column flex-md-row">
    <%- include('partials/sidebar', { currentPage: 'faqfiles' }) %>
    <div class="flex-grow-1">
        <%- include('partials/header') %>
        <div class="container-fluid px-3 py-3">
            <!-- Upload Card -->
            <div class="card">
                <div class="card-header bg-success text-white">
                    <i class="fas fa-cloud-upload-alt me-2"></i>Upload FAQ Files (Multiple JSON allowed)
                </div>
                <div class="card-body">
                    <form id="upload-form" enctype="multipart/form-data">
                        <div class="input-group">
                            <input type="file" class="form-control" id="file-input" accept=".json" multiple required>
                            <button class="btn btn-primary" type="submit"><i class="fas fa-upload"></i> Upload</button>
                        </div>
                        <small class="text-muted">File must be named: faq_&lt;threadID&gt;.json</small>
                    </form>
                    <div id="upload-result" class="mt-2"></div>
                </div>
            </div>

            <!-- File List Card with Bulk Actions -->
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-question-circle me-2"></i>FAQ Files (cache/faq)</span>
                    <div>
                        <button class="btn btn-sm btn-success" id="bulk-download-btn" disabled onclick="bulkDownload()"><i class="fas fa-download"></i> Download Selected</button>
                        <button class="btn btn-sm btn-danger" id="bulk-delete-btn" disabled onclick="bulkDelete()"><i class="fas fa-trash"></i> Delete Selected</button>
                        <button class="btn btn-sm btn-light ms-2" onclick="loadFiles()"><i class="fas fa-sync-alt"></i> Refresh</button>
                    </div>
                </div>
                <div class="card-body table-responsive">
                    <table id="files-table" class="table table-hover" style="width:100%">
                        <thead>
                            <tr>
                                <th><input type="checkbox" id="select-all"></th>
                                <th>#</th>
                                <th>Group ID</th>
                                <th>Filename</th>
                                <th>Questions</th>
                                <th>Size (KB)</th>
                                <th>Modified</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
        <%- include('partials/footer') %>
    </div>
</div>

<!-- View Modal -->
<div class="modal fade" id="viewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">FAQ Content - <span id="modal-group-id"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <pre id="modal-content" style="max-height: 500px; overflow-y: auto;">Loading...</pre>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
<script>
    let dataTable;
    let viewModal;

    $(document).ready(function() {
        viewModal = new bootstrap.Modal(document.getElementById('viewModal'));
        initDataTable();
    });

    function initDataTable() {
        if (dataTable) dataTable.destroy();
        dataTable = $('#files-table').DataTable({
            ajax: {
                url: '/api/faqfiles',
                dataSrc: ''
            },
            columns: [
                { data: null, orderable: false, render: d => `<input type="checkbox" class="file-checkbox" value="${d.filename}">` },
                { data: null, render: (d, t, r, meta) => meta.row + 1 },
                { data: 'groupId', defaultContent: 'Unknown' },
                { data: 'filename' },
                { data: 'questionCount', defaultContent: 0 },
                { data: 'size', render: d => (d / 1024).toFixed(1) },
                { data: 'modified', render: d => new Date(d).toLocaleString() },
                {
                    data: 'filename',
                    orderable: false,
                    render: function(data) {
                        return `
                            <button class="btn btn-sm btn-outline-info" onclick="viewFile('${data}')" title="View"><i class="fas fa-eye"></i></button>
                            <a href="/api/faqfiles/download/${encodeURIComponent(data)}" class="btn btn-sm btn-outline-success" title="Download"><i class="fas fa-download"></i></a>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteSingle('${data}')" title="Delete"><i class="fas fa-trash"></i></button>
                        `;
                    }
                }
            ],
            order: [[5, 'desc']],
            pageLength: 25,
            lengthMenu: [10, 25, 50, 100],
            language: { search: "", searchPlaceholder: "Search..." },
            initComplete: function() {
                $('.dataTables_filter input').addClass('form-control');
                updateBulkButtons();
            },
            drawCallback: updateBulkButtons
        });
    }

    $('#select-all').on('change', function() {
        $('.file-checkbox').prop('checked', this.checked);
        updateBulkButtons();
    });
    $(document).on('change', '.file-checkbox', updateBulkButtons);

    function updateBulkButtons() {
        const checked = $('.file-checkbox:checked').length;
        $('#bulk-download-btn').prop('disabled', checked === 0);
        $('#bulk-delete-btn').prop('disabled', checked === 0);
    }

    function getSelectedFiles() {
        return $('.file-checkbox:checked').map((i, el) => el.value).get();
    }

    async function bulkDownload() {
        const files = getSelectedFiles();
        if (!files.length) return;
        const res = await fetch('/api/faqfiles/bulk-download', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ files })
        });
        if (res.ok) {
            const blob = await res.blob();
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'faqfiles.zip';
            a.click();
        } else alert('Download failed.');
    }

    async function bulkDelete() {
        const files = getSelectedFiles();
        if (!files.length) return;
        if (!confirm(`Delete ${files.length} file(s)?`)) return;
        const res = await fetch('/api/faqfiles/bulk-delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ files })
        });
        const data = await res.json();
        if (data.success) {
            alert(`Deleted ${data.deleted.length} file(s).`);
            dataTable.ajax.reload(null, false);
            $('#select-all').prop('checked', false);
        } else alert('Bulk delete failed.');
    }

    window.deleteSingle = async function(filename) {
        if (!confirm(`Delete ${filename}?`)) return;
        const res = await fetch(`/api/faqfiles/${encodeURIComponent(filename)}`, { method: 'DELETE' });
        if (res.ok) dataTable.ajax.reload(null, false);
        else alert('Delete failed.');
    }

    window.viewFile = async function(filename) {
        document.getElementById('modal-group-id').innerText = filename.replace('faq_', '').replace('.json', '');
        document.getElementById('modal-content').innerText = 'Loading...';
        viewModal.show();
        try {
            const res = await fetch(`/api/faqfiles/view/${encodeURIComponent(filename)}`);
            const data = await res.json();
            let output = '';
            data.forEach((item, i) => {
                output += `[${i+1}] Q: ${item.question}\n    A: ${item.answer}\n\n`;
            });
            document.getElementById('modal-content').innerText = output || 'No questions.';
        } catch (e) {
            document.getElementById('modal-content').innerText = 'Failed to load.';
        }
    }

    function loadFiles() {
        dataTable.ajax.reload(null, false);
    }

    document.getElementById('upload-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const input = document.getElementById('file-input');
        if (!input.files.length) return;
        const formData = new FormData();
        [...input.files].forEach(f => formData.append('files', f));
        const resultDiv = document.getElementById('upload-result');
        resultDiv.innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin"></i> Uploading...</span>';
        try {
            const res = await fetch('/api/faqfiles/upload', { method: 'POST', body: formData });
            const data = await res.json();
            if (data.success) {
                let msg = `Uploaded ${data.uploaded.length} file(s).`;
                if (data.failed.length) msg += ` Failed: ${data.failed.length}`;
                resultDiv.innerHTML = `<span class="text-success">${msg}</span>`;
                input.value = '';
                dataTable.ajax.reload(null, false);
            } else {
                resultDiv.innerHTML = `<span class="text-danger">${data.error}</span>`;
            }
        } catch (err) {
            resultDiv.innerHTML = `<span class="text-danger">Upload failed</span>`;
        }
    });
</script>
</body>
</html>