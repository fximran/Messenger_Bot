<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings - Bot Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: #f8f9fa; }
        .card { margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        textarea { font-family: 'Courier New', monospace; font-size: 13px; }
    </style>
</head>
<body>
<div class="d-flex flex-column flex-md-row">
    <%- include('partials/sidebar', { currentPage: 'settings' }) %>
    <div class="flex-grow-1">
        <%- include('partials/header') %>
        <div class="container-fluid px-3 py-3">
            <!-- Quick Bot Settings -->
            <div class="card">
                <div class="card-header bg-primary text-white"><i class="fas fa-sliders-h me-2"></i>Quick Bot Settings</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">🤖 Bot Name</label>
                            <input type="text" id="quick-botname" class="form-control" placeholder="e.g., Jarvis">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">🔧 Command Prefix</label>
                            <input type="text" id="quick-prefix" class="form-control" placeholder="e.g., /">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">🌐 Bot Language</label>
                            <select id="quick-language" class="form-select">
                                <option value="en">English</option>
                                <option value="bn">Bangla</option>
                                <option value="hi">Hindi</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">🐛 Debug Mode</label>
                            <select id="quick-debug" class="form-select">
                                <option value="false">❌ OFF</option>
                                <option value="true">✅ ON</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">👑 Admin IDs</label>
                            <input type="text" id="quick-adminbot" class="form-control" placeholder="ID1, ID2">
                            <small class="text-muted">Comma separated list for ADMINBOT</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">🆔 Bot Facebook ID (NDH)</label>
                            <input type="text" id="quick-ndh" class="form-control" placeholder="ID1, ID2 (first used as Bot ID)">
                            <small class="text-muted">Comma separated list for NDH</small>
                        </div>
                    </div>
                    <button class="btn btn-success" onclick="saveQuickSettings()"><i class="fas fa-save"></i> Save Settings</button>
                    <span id="quick-result" class="ms-2"></span>
                </div>
            </div>

            <!-- Advanced JSON Editor (Collapsible) -->
            <div class="card">
                <div class="card-header bg-secondary text-white d-flex justify-content-between">
                    <span><i class="fas fa-code me-2"></i>Advanced: config.json Editor</span>
                    <button class="btn btn-sm btn-outline-light" onclick="toggleJson()"><i class="fas fa-chevron-down" id="json-icon"></i></button>
                </div>
                <div class="card-body" id="json-body" style="display: none;">
                    <textarea id="config-editor" rows="10" class="form-control mb-2"></textarea>
                    <button class="btn btn-outline-secondary" onclick="loadConfig()">Load</button>
                    <button class="btn btn-primary" onclick="saveConfig()">Save JSON</button>
                    <span id="config-result" class="ms-2"></span>
                </div>
            </div>

            <!-- AppState Editor -->
            <div class="card">
                <div class="card-header bg-dark text-white"><i class="fas fa-key me-2"></i>appstate.json Editor</div>
                <div class="card-body">
                    <textarea id="appstate-editor" rows="6" class="form-control mb-2"></textarea>
                    <button class="btn btn-outline-secondary" onclick="loadAppState()">Load</button>
                    <button class="btn btn-primary" onclick="saveAppState()">Save</button>
                    <span id="appstate-result" class="ms-2"></span>
                </div>
            </div>
        </div>
        <%- include('partials/footer') %>
    </div>
</div>
<%- include('partials/scripts') %>
<script>
    async function loadConfig() {
        const res = await fetch('/api/config');
        const config = await res.json();
        document.getElementById('config-editor').value = formatJson(config);
        document.getElementById('quick-botname').value = config.BOTNAME || '';
        document.getElementById('quick-prefix').value = config.PREFIX || '/';
        document.getElementById('quick-language').value = config.language || 'en';

        // Load debug mode from global endpoint
        try {
            const debugRes = await fetch('/api/debug');
            const debugData = await debugRes.json();
            document.getElementById('quick-debug').value = debugData.debugMode ? 'true' : 'false';
        } catch(e) { console.error('Failed to load debug mode', e); }

        // ADMINBOT
        const admin = Array.isArray(config.ADMINBOT) ? config.ADMINBOT.join(', ') : config.ADMINBOT || '';
        document.getElementById('quick-adminbot').value = admin;

        // NDH
        const ndh = Array.isArray(config.NDH) ? config.NDH.join(', ') : config.NDH || '';
        document.getElementById('quick-ndh').value = ndh;
    }

    async function saveConfig() {
        const result = document.getElementById('config-result');
        try {
            const config = JSON.parse(document.getElementById('config-editor').value);
            result.innerHTML = 'Saving...';
            const res = await fetch('/api/config', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(config) });
            const data = await res.json();
            result.innerHTML = data.success ? '<span class="text-success">Saved!</span>' : `<span class="text-danger">${data.error}</span>`;
            if(data.success) loadConfig();
        } catch(e) { result.innerHTML = '<span class="text-danger">Invalid JSON</span>'; }
    }

    async function saveQuickSettings() {
        const result = document.getElementById('quick-result');
        result.innerHTML = 'Saving...';
        try {
            const res = await fetch('/api/config');
            const config = await res.json();
            config.BOTNAME = document.getElementById('quick-botname').value.trim();
            config.PREFIX = document.getElementById('quick-prefix').value.trim();
            config.language = document.getElementById('quick-language').value;

            const adminRaw = document.getElementById('quick-adminbot').value;
            config.ADMINBOT = adminRaw.split(',').map(id => id.trim()).filter(id => id);

            const ndhRaw = document.getElementById('quick-ndh').value;
            config.NDH = ndhRaw.split(',').map(id => id.trim()).filter(id => id);

            const saveRes = await fetch('/api/config', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(config) });
            if (!saveRes.ok) {
                const err = await saveRes.json();
                result.innerHTML = `<span class="text-danger">${err.error}</span>`;
                return;
            }

            // Save debug mode separately to global
            const debugValue = document.getElementById('quick-debug').value === 'true';
            const debugRes = await fetch('/api/debug', { 
                method:'POST', 
                headers:{'Content-Type':'application/json'}, 
                body: JSON.stringify({ debugMode: debugValue }) 
            });
            if (!debugRes.ok) {
                const err = await debugRes.json();
                result.innerHTML = `<span class="text-danger">Debug update failed: ${err.error}</span>`;
                return;
            }

            result.innerHTML = '<span class="text-success">Saved! Restart bot to apply.</span>';
            if(document.getElementById('json-body').style.display !== 'none') loadConfig();
        } catch(e) { 
            result.innerHTML = '<span class="text-danger">Failed</span>'; 
        }
    }

    function toggleJson() {
        const body = document.getElementById('json-body');
        const icon = document.getElementById('json-icon');
        if(body.style.display === 'none') {
            body.style.display = 'block';
            icon.className = 'fas fa-chevron-up';
            loadConfig();
        } else {
            body.style.display = 'none';
            icon.className = 'fas fa-chevron-down';
        }
    }

    async function loadAppState() {
        const res = await fetch('/api/appstate');
        const data = await res.json();
        document.getElementById('appstate-editor').value = formatJson(data);
    }

    async function saveAppState() {
        const result = document.getElementById('appstate-result');
        try {
            const state = JSON.parse(document.getElementById('appstate-editor').value);
            result.innerHTML = 'Saving...';
            const res = await fetch('/api/appstate', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(state) });
            const data = await res.json();
            result.innerHTML = data.success ? '<span class="text-success">Saved!</span>' : `<span class="text-danger">${data.error}</span>`;
        } catch(e) { result.innerHTML = '<span class="text-danger">Invalid JSON</span>'; }
    }

    loadConfig();
    loadAppState();
</script>
</body>
</html>