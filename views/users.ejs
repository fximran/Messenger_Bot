<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users - Bot Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: #f8f9fa; }
        .card { margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .profile-icon { font-size: 4rem; color: #0d6efd; }
    </style>
</head>
<body>
<div class="d-flex flex-column flex-md-row">
    <%- include('partials/sidebar', { currentPage: 'users' }) %>
    <div class="flex-grow-1">
        <%- include('partials/header') %>
        <div class="container-fluid px-3 py-3">
            <!-- Profile Card -->
            <div class="card">
                <div class="card-header bg-info text-white"><i class="fas fa-id-card me-2"></i>Your Profile</div>
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-2 text-center">
                            <i class="fas fa-user-circle profile-icon"></i>
                        </div>
                        <div class="col-md-10">
                            <h4><%= user.name %></h4>
                            <p class="mb-1"><i class="fas fa-envelope me-2"></i><%= user.email %></p>
                            <p class="mb-1"><i class="fas fa-shield-alt me-2"></i>Permission Level: <span class="badge bg-primary"><%= user.permission %></span></p>
                            <p class="mb-0"><i class="fas fa-calendar me-2"></i>Member since: N/A</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Members Management -->
            <div class="card">
                <div class="card-header bg-secondary text-white d-flex justify-content-between">
                    <span><i class="fas fa-users me-2"></i>Members Management</span>
                    <button class="btn btn-sm btn-light" onclick="showAddUserModal()"><i class="fas fa-plus"></i> Add Member</button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Perm</th><th>Created</th><th>Actions</th></tr></thead>
                            <tbody id="users-table-body"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <%- include('partials/footer') %>
    </div>
</div>

<!-- Add/Edit User Modal -->
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userModalTitle">Add Member</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="edit-user-id">
                <div class="mb-3"><label class="form-label">Name</label><input type="text" id="user-name" class="form-control"></div>
                <div class="mb-3"><label class="form-label">Email</label><input type="email" id="user-email" class="form-control"></div>
                <div class="mb-3"><label class="form-label">Password</label><input type="password" id="user-password" class="form-control" placeholder="Leave blank to keep"></div>
                <div class="mb-3"><label class="form-label">Permission</label>
                    <select id="user-permission" class="form-select">
                        <option value="0">0 - Member</option><option value="1">1 - Mod</option><option value="2">2 - Admin</option><option value="3">3 - Owner</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveUser()">Save</button>
            </div>
        </div>
    </div>
</div>

<%- include('partials/scripts') %>
<script>
    let currentUser = <%- JSON.stringify(user) %>;
    let userModal;
    document.addEventListener('DOMContentLoaded', () => {
        userModal = new bootstrap.Modal(document.getElementById('userModal'));
        loadUsers();
    });

    async function loadUsers() {
        const res = await fetch('/api/users');
        const users = await res.json();
        const tbody = document.getElementById('users-table-body');
        tbody.innerHTML = '';
        users.forEach(u => {
            const tr = document.createElement('tr');
            tr.innerHTML = `<td>${u.id}</td><td>${u.name}</td><td>${u.email}</td><td>${u.permission}</td><td>${u.created_at?.split(' ')[0]||''}</td>
                <td>
                    <button class="btn btn-sm btn-outline-primary" onclick="editUser(${u.id})"><i class="fas fa-edit"></i></button>
                    ${currentUser.permission >= 3 ? `<button class="btn btn-sm btn-outline-danger" onclick="deleteUser(${u.id})"><i class="fas fa-trash"></i></button>` : ''}
                </td>`;
            tbody.appendChild(tr);
        });
    }

    window.editUser = async (id) => {
        const res = await fetch('/api/users');
        const user = (await res.json()).find(u=>u.id===id);
        if(!user) return;
        document.getElementById('userModalTitle').innerText = 'Edit Member';
        document.getElementById('edit-user-id').value = user.id;
        document.getElementById('user-name').value = user.name;
        document.getElementById('user-email').value = user.email;
        document.getElementById('user-password').value = '';
        document.getElementById('user-permission').value = user.permission;
        userModal.show();
    };

    window.deleteUser = async (id) => {
        if(!confirm('Delete user?')) return;
        const res = await fetch(`/api/users/${id}`, {method:'DELETE'});
        if(res.ok) loadUsers();
        else alert('Delete failed');
    };

    window.showAddUserModal = () => {
        document.getElementById('userModalTitle').innerText = 'Add Member';
        document.getElementById('edit-user-id').value = '';
        document.getElementById('user-name').value = '';
        document.getElementById('user-email').value = '';
        document.getElementById('user-password').value = '';
        document.getElementById('user-permission').value = '0';
        userModal.show();
    };

    window.saveUser = async () => {
        const id = document.getElementById('edit-user-id').value;
        const name = document.getElementById('user-name').value;
        const email = document.getElementById('user-email').value;
        const password = document.getElementById('user-password').value;
        const perm = parseInt(document.getElementById('user-permission').value);
        if(!name||!email) return alert('Name/Email required');
        if(!id && !password) return alert('Password required');
        const payload = {name,email,permission:perm};
        if(password) payload.password = password;
        const url = id ? `/api/users/${id}` : '/api/users';
        const method = id ? 'PUT' : 'POST';
        const res = await fetch(url, {method, headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload)});
        if(res.ok) { userModal.hide(); loadUsers(); }
        else alert((await res.json()).error || 'Save failed');
    };
</script>
</body>
</html>