<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auto Messages - Bot Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: #f8f9fa; }
        .card { margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .modal-body pre { background: #1e1e1e; color: #ddd; padding: 15px; border-radius: 5px; }
    </style>
</head>
<body>
<div class="d-flex flex-column flex-md-row">
    <%- include('partials/sidebar', { currentPage: 'automessages' }) %>
    <div class="flex-grow-1">
        <%- include('partials/header') %>
        <div class="container-fluid px-3 py-3">
            <!-- Upload Card -->
            <div class="card">
                <div class="card-header bg-success text-white">
                    <i class="fas fa-cloud-upload-alt me-2"></i>Upload Auto Message File
                </div>
                <div class="card-body">
                    <form id="upload-form" enctype="multipart/form-data">
                        <div class="input-group">
                            <input type="file" class="form-control" id="file-input" accept=".json" required>
                            <button class="btn btn-primary" type="submit"><i class="fas fa-upload"></i> Upload</button>
                        </div>
                        <small class="text-muted">File must be named: automessage_&lt;threadID&gt;.json</small>
                    </form>
                    <div id="upload-result" class="mt-2"></div>
                </div>
            </div>

            <!-- File List Card -->
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between">
                    <span><i class="fas fa-clock me-2"></i>Auto Message Files (cache/automessage)</span>
                    <button class="btn btn-sm btn-light" onclick="loadFiles()"><i class="fas fa-sync-alt"></i> Refresh</button>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Group ID</th>
                                <th>Filename</th>
                                <th>Status</th>
                                <th>Messages</th>
                                <th>Modified</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="file-list-body">
                            <tr><td colspan="7" class="text-center">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <%- include('partials/footer') %>
    </div>
</div>

<!-- View Messages Modal -->
<div class="modal fade" id="viewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Auto Messages - <span id="modal-group-id"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <pre id="modal-content" style="max-height: 500px; overflow-y: auto;">Loading...</pre>
            </div>
        </div>
    </div>
</div>

<%- include('partials/scripts') %>
<script>
    let viewModal;
    document.addEventListener('DOMContentLoaded', () => {
        viewModal = new bootstrap.Modal(document.getElementById('viewModal'));
        loadFiles();
    });

    async function loadFiles() {
        const tbody = document.getElementById('file-list-body');
        tbody.innerHTML = '<tr><td colspan="7" class="text-center">Loading...</td></tr>';
        try {
            const res = await fetch('/api/automessages');
            const files = await res.json();
            if (files.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center">No files found.</td></tr>';
                return;
            }
            tbody.innerHTML = '';
            files.forEach((f, i) => {
                const row = document.createElement('tr');
                const modified = new Date(f.modified).toLocaleString();
                const statusBadge = f.enabled 
                    ? '<span class="badge bg-success">Enabled</span>' 
                    : '<span class="badge bg-secondary">Disabled</span>';
                row.innerHTML = `
                    <td>${i+1}</td>
                    <td>${f.groupId}</td>
                    <td>${f.filename}</td>
                    <td>${statusBadge}</td>
                    <td>${f.messageCount}</td>
                    <td>${modified}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-info" onclick="viewFile('${f.filename}')" title="View Messages"><i class="fas fa-eye"></i></button>
                        <a href="/api/automessages/download/${encodeURIComponent(f.filename)}" class="btn btn-sm btn-outline-success" title="Download"><i class="fas fa-download"></i></a>
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteFile('${f.filename}')" title="Delete"><i class="fas fa-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(row);
            });
        } catch (e) {
            tbody.innerHTML = '<tr><td colspan="7" class="text-center text-danger">Failed to load files</td></tr>';
        }
    }

    async function viewFile(filename) {
        document.getElementById('modal-group-id').innerText = filename.replace('automessage_', '').replace('.json', '');
        document.getElementById('modal-content').innerText = 'Loading...';
        viewModal.show();
        try {
            const res = await fetch(`/api/automessages/view/${encodeURIComponent(filename)}`);
            const data = await res.json();
            // Format messages nicely
            let output = `Enabled: ${data.enabled}\n`;
            output += `Default Interval: ${data.defaultInterval} minutes\n`;
            output += `Total Messages: ${data.messages?.length || 0}\n\n`;
            output += `=== MESSAGES ===\n`;
            if (data.messages) {
                data.messages.forEach((m, idx) => {
                    const interval = m.interval || `Default (${data.defaultInterval})`;
                    output += `\n[${idx+1}] Interval: ${interval} min\n    Text: ${m.text}\n`;
                });
            }
            document.getElementById('modal-content').innerText = output;
        } catch (e) {
            document.getElementById('modal-content').innerText = 'Failed to load file content.';
        }
    }

    async function deleteFile(filename) {
        if (!confirm(`Delete ${filename}?`)) return;
        try {
            const res = await fetch(`/api/automessages/${encodeURIComponent(filename)}`, { method: 'DELETE' });
            if (res.ok) loadFiles();
            else alert('Delete failed');
        } catch (e) {
            alert('Error: ' + e.message);
        }
    }

    document.getElementById('upload-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const fileInput = document.getElementById('file-input');
        const resultDiv = document.getElementById('upload-result');
        if (!fileInput.files[0]) return;
        const formData = new FormData();
        formData.append('file', fileInput.files[0]);
        resultDiv.innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin"></i> Uploading...</span>';
        try {
            const res = await fetch('/api/automessages/upload', { method: 'POST', body: formData });
            const data = await res.json();
            if (data.success) {
                resultDiv.innerHTML = '<span class="text-success">Uploaded!</span>';
                fileInput.value = '';
                loadFiles();
            } else {
                resultDiv.innerHTML = `<span class="text-danger">${data.error}</span>`;
            }
        } catch (err) {
            resultDiv.innerHTML = `<span class="text-danger">Upload failed</span>`;
        }
    });
</script>
</body>
</html>