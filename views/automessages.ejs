<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auto Messages - Bot Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <style>
        body { background: #f8f9fa; }
        .card { margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .modal-body pre { background: #1e1e1e; color: #ddd; padding: 15px; border-radius: 5px; }
    </style>
</head>
<body>
<div class="d-flex flex-column flex-md-row">
    <%- include('partials/sidebar', { currentPage: 'automessages' }) %>
    <div class="flex-grow-1">
        <%- include('partials/header') %>
        <div class="container-fluid px-3 py-3">
            <!-- Upload Card -->
            <div class="card">
                <div class="card-header bg-success text-white">
                    <i class="fas fa-cloud-upload-alt me-2"></i>Upload Auto Message Files (Multiple JSON allowed)
                </div>
                <div class="card-body">
                    <form id="upload-form" enctype="multipart/form-data">
                        <div class="input-group">
                            <input type="file" class="form-control" id="file-input" accept=".json" multiple required>
                            <button class="btn btn-primary" type="submit"><i class="fas fa-upload"></i> Upload</button>
                        </div>
                        <small class="text-muted">File must be named: automessage_&lt;threadID&gt;.json</small>
                    </form>
                    <div id="upload-result" class="mt-2"></div>
                </div>
            </div>

            <!-- File List Card with Bulk Actions -->
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-clock me-2"></i>Auto Message Files (cache/automessage)</span>
                    <div>
                        <button class="btn btn-sm btn-success" id="bulk-download-btn" disabled onclick="bulkDownload()"><i class="fas fa-download"></i> Download Selected</button>
                        <button class="btn btn-sm btn-danger" id="bulk-delete-btn" disabled onclick="bulkDelete()"><i class="fas fa-trash"></i> Delete Selected</button>
                        <button class="btn btn-sm btn-light ms-2" onclick="loadFiles()"><i class="fas fa-sync-alt"></i> Refresh</button>
                    </div>
                </div>
                <div class="card-body table-responsive">
                    <table id="files-table" class="table table-hover" style="width:100%">
                        <thead>
                            <tr>
                                <th><input type="checkbox" id="select-all"></th>
                                <th>#</th>
                                <th>Group ID</th>
                                <th>Filename</th>
                                <th>Status</th>
                                <th>Messages</th>
                                <th>Size (KB)</th>
                                <th>Modified</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="file-list-body">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <%- include('partials/footer') %>
    </div>
</div>

<!-- View Messages Modal -->
<div class="modal fade" id="viewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Auto Messages - <span id="modal-group-id"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <pre id="modal-content" style="max-height: 500px; overflow-y: auto;">Loading...</pre>
            </div>
        </div>
    </div>
</div>

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Bootstrap -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<!-- DataTables -->
<script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
<script>
    let dataTable;
    let viewModal;

    $(document).ready(function() {
        viewModal = new bootstrap.Modal(document.getElementById('viewModal'));
        initDataTable();
    });

    function initDataTable() {
        if (dataTable) dataTable.destroy();
        dataTable = $('#files-table').DataTable({
            ajax: {
                url: '/api/automessages',
                dataSrc: ''
            },
            columns: [
                { 
                    data: null,
                    orderable: false,
                    render: function(data) {
                        return `<input type="checkbox" class="file-checkbox" value="${data.filename}">`;
                    }
                },
                { 
                    data: null,
                    render: function(data, type, row, meta) {
                        return meta.row + 1;
                    }
                },
                { data: 'groupId', defaultContent: 'Unknown' },
                { data: 'filename' },
                { 
                    data: 'enabled',
                    render: function(data) {
                        return data ? '<span class="badge bg-success">Enabled</span>' : '<span class="badge bg-secondary">Disabled</span>';
                    }
                },
                { data: 'messageCount', defaultContent: 0 },
                { 
                    data: 'size',
                    render: function(data) {
                        return (data / 1024).toFixed(1);
                    }
                },
                { 
                    data: 'modified',
                    render: function(data) {
                        return new Date(data).toLocaleString();
                    }
                },
                {
                    data: 'filename',
                    orderable: false,
                    render: function(data) {
                        return `
                            <button class="btn btn-sm btn-outline-info" onclick="viewFile('${data}')" title="View Messages"><i class="fas fa-eye"></i></button>
                            <a href="/api/automessages/download/${encodeURIComponent(data)}" class="btn btn-sm btn-outline-success" title="Download"><i class="fas fa-download"></i></a>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteSingle('${data}')" title="Delete"><i class="fas fa-trash"></i></button>
                        `;
                    }
                }
            ],
            order: [[6, 'desc']],
            pageLength: 25,
            lengthMenu: [10, 25, 50, 100],
            language: { search: "", searchPlaceholder: "Search..." },
            initComplete: function() {
                $('.dataTables_filter input').addClass('form-control');
                updateBulkButtons();
            },
            drawCallback: function() {
                updateBulkButtons();
            }
        });
    }

    // Checkbox handling
    $('#select-all').on('change', function() {
        $('.file-checkbox').prop('checked', this.checked);
        updateBulkButtons();
    });
    
    $(document).on('change', '.file-checkbox', function() {
        updateBulkButtons();
    });

    function updateBulkButtons() {
        const checked = $('.file-checkbox:checked').length;
        $('#bulk-download-btn').prop('disabled', checked === 0);
        $('#bulk-delete-btn').prop('disabled', checked === 0);
    }

    function getSelectedFiles() {
        return $('.file-checkbox:checked').map(function() { return this.value; }).get();
    }

    async function bulkDownload() {
        const files = getSelectedFiles();
        if (files.length === 0) return;
        const res = await fetch('/api/automessages/bulk-download', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ files })
        });
        if (res.ok) {
            const blob = await res.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'automessages.zip';
            document.body.appendChild(a);
            a.click();
            a.remove();
        } else {
            alert('Failed to download selected files.');
        }
    }

    async function bulkDelete() {
        const files = getSelectedFiles();
        if (files.length === 0) return;
        if (!confirm(`Are you sure you want to delete ${files.length} file(s)?`)) return;
        const res = await fetch('/api/automessages/bulk-delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ files })
        });
        const data = await res.json();
        if (data.success) {
            alert(`Deleted ${data.deleted.length} file(s).${data.failed.length ? ` Failed: ${data.failed.length}` : ''}`);
            dataTable.ajax.reload(null, false);
            $('#select-all').prop('checked', false);
        } else {
            alert('Bulk delete failed.');
        }
    }

    window.deleteSingle = async function(filename) {
        if (!confirm(`Delete ${filename}?`)) return;
        const res = await fetch(`/api/automessages/${encodeURIComponent(filename)}`, { method: 'DELETE' });
        if (res.ok) {
            dataTable.ajax.reload(null, false);
        } else {
            alert('Delete failed');
        }
    }

    window.viewFile = async function(filename) {
        document.getElementById('modal-group-id').innerText = filename.replace('automessage_', '').replace('.json', '');
        document.getElementById('modal-content').innerText = 'Loading...';
        viewModal.show();
        try {
            const res = await fetch(`/api/automessages/view/${encodeURIComponent(filename)}`);
            const data = await res.json();
            let output = `Enabled: ${data.enabled}\n`;
            output += `Default Interval: ${data.defaultInterval} minutes\n`;
            output += `Total Messages: ${data.messages?.length || 0}\n\n`;
            output += `=== MESSAGES ===\n`;
            if (data.messages) {
                data.messages.forEach((m, idx) => {
                    const interval = m.interval || `Default (${data.defaultInterval})`;
                    output += `\n[${idx+1}] Interval: ${interval} min\n    Text: ${m.text}\n`;
                });
            }
            document.getElementById('modal-content').innerText = output;
        } catch (e) {
            document.getElementById('modal-content').innerText = 'Failed to load file content.';
        }
    }

    function loadFiles() {
        dataTable.ajax.reload(null, false);
    }

    // Upload form
    document.getElementById('upload-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const fileInput = document.getElementById('file-input');
        const resultDiv = document.getElementById('upload-result');
        if (!fileInput.files.length) return;
        const formData = new FormData();
        for (const file of fileInput.files) {
            formData.append('files', file);
        }
        resultDiv.innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin"></i> Uploading...</span>';
        try {
            const res = await fetch('/api/automessages/upload', { method: 'POST', body: formData });
            const data = await res.json();
            if (data.success) {
                let msg = `Uploaded ${data.uploaded.length} file(s).`;
                if (data.failed.length) msg += ` Failed: ${data.failed.length}`;
                resultDiv.innerHTML = `<span class="text-success">${msg}</span>`;
                fileInput.value = '';
                dataTable.ajax.reload(null, false);
            } else {
                resultDiv.innerHTML = `<span class="text-danger">${data.error}</span>`;
            }
        } catch (err) {
            resultDiv.innerHTML = `<span class="text-danger">Upload failed</span>`;
        }
    });
</script>
</body>
</html>